{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "properties": {
    "accepted": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "bucket": {
      "description": "Cluster bucket emitted by the data-science layer when looking for missing scenarios in a dataset.",
      "enum": [
        "captured",
        "adjacent",
        "emerging",
        "edge"
      ],
      "type": [
        "string",
        "null"
      ]
    },
    "clusterId": {
      "type": [
        "string",
        "null"
      ]
    },
    "clusterLabel": {
      "type": [
        "string",
        "null"
      ]
    },
    "confidence": {
      "format": "double",
      "type": [
        "number",
        "null"
      ]
    },
    "count": {
      "format": "uint32",
      "minimum": 0.0,
      "type": "integer"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "enum": [
        "adversarial",
        "nonEnglish",
        "toolFailure",
        "longTurn"
      ],
      "type": "string"
    },
    "label": {
      "type": "string"
    }
  },
  "required": [
    "count",
    "id",
    "kind",
    "label"
  ],
  "title": "BacktestDataScenario",
  "type": "object"
}