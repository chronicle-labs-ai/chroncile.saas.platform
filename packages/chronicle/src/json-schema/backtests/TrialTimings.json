{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Per-phase timing bookkeeping. Each pair is `(started_at, finished_at)`; `None` until that phase starts/ends.",
  "properties": {
    "agentRunFinishedAt": {
      "format": "date-time",
      "type": [
        "string",
        "null"
      ]
    },
    "agentRunStartedAt": {
      "format": "date-time",
      "type": [
        "string",
        "null"
      ]
    },
    "agentSetupFinishedAt": {
      "format": "date-time",
      "type": [
        "string",
        "null"
      ]
    },
    "agentSetupStartedAt": {
      "format": "date-time",
      "type": [
        "string",
        "null"
      ]
    },
    "envSetupFinishedAt": {
      "format": "date-time",
      "type": [
        "string",
        "null"
      ]
    },
    "envSetupStartedAt": {
      "format": "date-time",
      "type": [
        "string",
        "null"
      ]
    },
    "verifierFinishedAt": {
      "format": "date-time",
      "type": [
        "string",
        "null"
      ]
    },
    "verifierStartedAt": {
      "format": "date-time",
      "type": [
        "string",
        "null"
      ]
    }
  },
  "title": "TrialTimings",
  "type": "object"
}