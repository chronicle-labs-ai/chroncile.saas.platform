{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "properties": {
    "fileFormat": {
      "enum": [
        "jsonl",
        "csv"
      ],
      "type": "string"
    },
    "includedFields": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "outputType": {
      "enum": [
        "sse",
        "webhook",
        "file",
        "console"
      ],
      "type": "string"
    },
    "transformTemplate": {
      "type": "string"
    },
    "webhookUrl": {
      "type": "string"
    }
  },
  "required": [
    "fileFormat",
    "includedFields",
    "outputType",
    "transformTemplate",
    "webhookUrl"
  ],
  "title": "OutputConfig",
  "type": "object"
}