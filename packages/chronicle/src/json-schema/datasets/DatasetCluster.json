{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "properties": {
    "color": {
      "description": "CSS color for the cluster (e.g. `\"var(--c-event-teal)\"`).",
      "type": "string"
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "id": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "similarityCenter": {
      "description": "Optional pre-computed centroid hint in normalized [0..1] space.",
      "items": {
        "format": "double",
        "type": "number"
      },
      "maxItems": 2,
      "minItems": 2,
      "type": [
        "array",
        "null"
      ]
    },
    "traceIds": {
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "color",
    "id",
    "label",
    "traceIds"
  ],
  "title": "DatasetCluster",
  "type": "object"
}