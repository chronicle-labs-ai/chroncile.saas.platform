{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "properties": {
    "addedAt": {
      "format": "date-time",
      "type": [
        "string",
        "null"
      ]
    },
    "addedBy": {
      "type": [
        "string",
        "null"
      ]
    },
    "clusterId": {
      "type": [
        "string",
        "null"
      ]
    },
    "durationMs": {
      "format": "uint32",
      "minimum": 0.0,
      "type": "integer"
    },
    "embedding": {
      "description": "Pre-computed 2D embedding in normalized `[-1, 1]` space.",
      "items": {
        "format": "double",
        "type": "number"
      },
      "maxItems": 2,
      "minItems": 2,
      "type": [
        "array",
        "null"
      ]
    },
    "eventCount": {
      "format": "uint32",
      "minimum": 0.0,
      "type": "integer"
    },
    "label": {
      "type": "string"
    },
    "note": {
      "type": [
        "string",
        "null"
      ]
    },
    "primarySource": {
      "type": "string"
    },
    "sources": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "split": {
      "description": "Train / validation / test split assignment.",
      "enum": [
        "train",
        "validation",
        "test"
      ],
      "type": [
        "string",
        "null"
      ]
    },
    "startedAt": {
      "format": "date-time",
      "type": "string"
    },
    "status": {
      "description": "Health status of a trace as judged by the dataset owner.",
      "enum": [
        "ok",
        "warn",
        "error"
      ],
      "type": "string"
    },
    "traceId": {
      "type": "string"
    }
  },
  "required": [
    "durationMs",
    "eventCount",
    "label",
    "primarySource",
    "sources",
    "startedAt",
    "status",
    "traceId"
  ],
  "title": "TraceSummary",
  "type": "object"
}