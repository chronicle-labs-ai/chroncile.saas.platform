{
  "$schema": "https://boneyard.vercel.app/schema/config.json",
  "out": "./src/bones",
  "breakpoints": [375, 768, 1280],
  "wait": 800,
  "color": "var(--c-wash-3)",
  "darkColor": "var(--c-wash-3)",
  "animate": "pulse",
  "transition": 200,
  "skeletons": {
    "profile-card": {
      "route": "/iframe.html?id=primitives-skeleton--profile-card&viewMode=story"
    },
    "env-card": {
      "route": "/iframe.html?id=env-manager-envcard--loading&viewMode=story"
    }
  }
}
