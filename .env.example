# ── Chronicle Labs Platform ──
# Copy to .env and fill in values for local development.
# For production, use Fly.io secrets (backend) and Vercel env vars (frontend).

# ── Database ──
# Supabase: use session pooler (port 6543) for SQLx compatibility.
# Transaction pooler (port 5432) does NOT work with prepared statements.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Rust Backend ──
API_HOST=0.0.0.0
API_PORT=8080
BACKEND_MODE=memory
RUST_LOG=info,tower_http=debug

# Auth (min 32 chars, generate with: openssl rand -base64 32)
AUTH_SECRET=generate-a-secret-at-least-32-characters-long

# Service-to-service auth between frontend and backend
SERVICE_SECRET=generate-another-secret-at-least-32-characters

# Encryption for stored tokens (64 hex chars = 32 bytes, generate with: openssl rand -hex 32)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ── Frontend ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# ── Google OAuth ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Pipedream ──
PIPEDREAM_CLIENT_ID=
PIPEDREAM_CLIENT_SECRET=
PIPEDREAM_PROJECT_ID=
PIPEDREAM_ENVIRONMENT=development

# ── Stripe ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
