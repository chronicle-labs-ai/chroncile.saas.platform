# env-manager Postgres (its own registry database)
DATABASE_URL="postgresql://chronicle:chronicle_dev@localhost:5432/env_manager"

# NextAuth
AUTH_SECRET=""
ENV_MANAGER_GOOGLE_CLIENT_ID=""
ENV_MANAGER_GOOGLE_CLIENT_SECRET=""

# Fly.io API
# Keep operator credentials in a local override or runtime platform secret store.
FLY_API_TOKEN=""
FLY_ORG_SLUG="chronicle-labs"

# Vercel API
# Keep operator credentials in a local override or runtime platform secret store.
VERCEL_API_TOKEN=""
VERCEL_PROJECT_ID=""
VERCEL_TEAM_ID=""

# Permanent environment Doppler access.
# env-manager uses these read-only service tokens to look up permanent backend
# and frontend values directly from Doppler during sync.
DOPPLER_PROJECT="chronicle-platform"
DOPPLER_DEV_BACKEND_CONFIG="dev_backend"
DOPPLER_DEV_BACKEND_TOKEN=""
DOPPLER_DEV_FRONTEND_CONFIG="dev_frontend"
DOPPLER_DEV_FRONTEND_TOKEN=""
DOPPLER_STG_BACKEND_CONFIG="stg_backend"
DOPPLER_STG_BACKEND_TOKEN=""
DOPPLER_STG_FRONTEND_CONFIG="stg_frontend"
DOPPLER_STG_FRONTEND_TOKEN=""
DOPPLER_PRD_BACKEND_CONFIG="prd_backend"
DOPPLER_PRD_BACKEND_TOKEN=""
DOPPLER_PRD_FRONTEND_CONFIG="prd_frontend"
DOPPLER_PRD_FRONTEND_TOKEN=""

# Optional fallbacks when Doppler access is not configured.
# Permanent environment frontend URLs (Vercel aliases or preview URLs)
VERCEL_PRODUCTION_URL="https://your-app.vercel.app"
VERCEL_STAGING_URL=""
VERCEL_DEV_URL=""

# Optional fallbacks when Doppler access is not configured.
SERVICE_SECRET_PRODUCTION=""
SERVICE_SECRET_STAGING=""
SERVICE_SECRET_DEV=""
# Fallback for ephemeral envs
SERVICE_SECRET=""
SERVICE_USER_ID="env-manager-service-account"

# GitHub API
# Keep operator credentials in a local override or runtime platform secret store.
GITHUB_TOKEN=""
GITHUB_OWNER=""
GITHUB_REPO=""

# Default secrets to copy to ephemeral environments (JSON blob)
SECRETS_TEMPLATE='{"AUTH_SECRET":"","STRIPE_SECRET_KEY":"","PIPEDREAM_CLIENT_ID":"","PIPEDREAM_CLIENT_SECRET":"","PIPEDREAM_PROJECT_ID":""}'

# Resend (email)
RESEND_API_KEY=""
RESEND_FROM_ADDRESS="Chronicle Labs <noreply@chronicle-labs.com>"

# Vercel Cron secret (protects cron endpoints)
CRON_SECRET=""

# k6 Cloud (Grafana Cloud) — load testing
# Generate a Stack API token from: Grafana stack → Testing & synthetics → Performance → Settings → Access → Stack token
# (NOT a Grafana Cloud Access Policy token — must be a k6-native token)
K6_CLOUD_API_TOKEN=""
# Stack ID and Project ID are shown on the same Settings → Access page
K6_CLOUD_STACK_ID=""
K6_CLOUD_PROJECT_ID=""
