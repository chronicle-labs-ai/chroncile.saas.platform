generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EnvironmentType {
  PRODUCTION
  STAGING
  DEVELOPMENT
  LOCAL
  EPHEMERAL
}

enum EnvironmentStatus {
  RUNNING
  STOPPED
  PROVISIONING
  DESTROYING
  ERROR
}

model Environment {
  id                 String            @id @default(cuid())
  name               String            @unique
  type               EnvironmentType
  status             EnvironmentStatus @default(PROVISIONING)
  gitBranch          String?
  gitSha             String?
  gitTag             String?
  flyAppName         String?
  flyAppUrl          String?
  flyDbName          String?
  vercelUrl          String?
  vercelDeploymentId String?
  vercelEnvVarId     String?
  isHealthy          Boolean           @default(false)
  lastHealthAt       DateTime?
  serviceSecret      String?
  dbTemplateId       String?
  provisionLog       String?
  errorLog           String?
  expiresAt          DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  healthChecks       HealthCheck[]
  stressTests        StressTest[]
  emailAssignments   EmailTemplateAssignment[]

  @@index([type])
  @@index([status])
}

model HealthCheck {
  id               String      @id @default(cuid())
  environmentId    String
  environment      Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  backendStatus    Int?
  frontendStatus   Int?
  backendMs        Int?
  frontendMs       Int?
  gitSha           String?
  serviceStatuses  Json?
  checkedAt        DateTime    @default(now())

  @@index([environmentId, checkedAt])
}

model StressTest {
  id              String      @id @default(cuid())
  environmentId   String
  environment     Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  k6TestRunId     String?
  name            String
  status          String      @default("queued")
  config          Json
  resultSummary   Json?
  k6Url           String?
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime    @default(now())

  @@index([environmentId, createdAt])
}

enum DbTemplateMode {
  FLY_DB       // Fork from a named Fly Postgres app
  ENVIRONMENT  // Fork from an existing environment's DB
  SEED_ONLY    // Fresh empty DB + run seed SQL
}

model DbTemplate {
  id          String         @id @default(cuid())
  name        String         @unique
  description String?
  mode        DbTemplateMode
  flyDbName   String?        // Fly Postgres app to fork from (FLY_DB mode)
  sourceEnvId String?        // Environment ID to fork from (ENVIRONMENT mode)
  seedSqlUrl  String?        // URL to a .sql file run after fork/create
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  lastUsedAt  DateTime?
}

// ── Developer Registry ──────────────────────────────────────────────────────

model Developer {
  id                    String   @id @default(cuid())
  name                  String   @unique
  email                 String?
  tunnelDomain          String
  dopplerSuffix         String
  dopplerFrontendToken  String?
  dopplerBackendToken   String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ── Email Template Registry ──────────────────────────────────────────────────

model EmailTemplateKey {
  id          String                    @id @default(cuid())
  key         String                    @unique
  name        String
  description String?
  variables   Json                      // [{ key, type, description, sampleValue }]
  category    String                    @default("transactional")
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  assignments EmailTemplateAssignment[]
}

model EmailTemplateAssignment {
  id               String            @id @default(cuid())
  templateKeyId    String
  templateKey      EmailTemplateKey  @relation(fields: [templateKeyId], references: [id], onDelete: Cascade)
  resendTemplateId String
  environmentId    String?
  environment      Environment?      @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([templateKeyId, environmentId])
  @@index([environmentId])
}
