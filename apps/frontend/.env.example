# Chronicle frontend configuration
# Copy this file to .env.local for local development.

# WorkOS (auth)
# Docs: https://workos.com/docs/authkit/nextjs#set-secrets
WORKOS_API_KEY=sk_test_replace_me
WORKOS_CLIENT_ID=client_replace_me
# Must match a Redirect URI configured in the WorkOS Dashboard
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/api/auth/callback
# 32+ chars used to encrypt the session cookie. Generate with: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=replace-me-32-or-more-characters-please

# Must match the backend SERVICE_SECRET for server-to-server requests
SERVICE_SECRET=generate-another-secret-at-least-32-characters

# Frontend and backend URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Daytona (sandbox terminal)
# Get your key at https://app.daytona.io
DAYTONA_API_KEY=dtn_replace_me
# Optional override; defaults to https://app.daytona.io/api
# DAYTONA_API_URL=https://app.daytona.io/api

# ── Data middleware (`apps/frontend/lib/data`) ────────────
# Each domain picks its data source independently:
#   mock       in-browser MockStore seeded from `packages/seeds`
#   app        Next.js routes under /api/* (host-app glue)
#   chronicle  direct browser → chronicle-backend
# Defaults to `mock` when unset.
NEXT_PUBLIC_DATA_AGENTS=mock
NEXT_PUBLIC_DATA_CONNECTIONS=mock
NEXT_PUBLIC_DATA_DATASETS=mock
NEXT_PUBLIC_DATA_TIMELINE=mock
NEXT_PUBLIC_DATA_BACKTESTS=mock
NEXT_PUBLIC_DATA_ENVIRONMENTS=mock

# Per-domain seed scenario (fixtures in `packages/seeds`):
#   default | empty | power-user (datasets only) | support-flow | chronicle-demo
#
# `support-flow` is a focused scenario where one `support-agent`
# handles inbound messages via Intercom, Shopify, Stripe, and Slack.
# The same trace ids are reused across all four domains, so a run
# in agents → conversation in timeline → row in datasets all line up.
# Set all four to `support-flow` to see the cohesive story.
#
# `chronicle-demo` mirrors the 3-minute product walkthrough — a
# single `billing-agent` for a subscription SaaS company wired to
# Intercom, Stripe, Salesforce, and Postgres (the product DB). Four
# happy-path traces pass; three are flagged by Chronicle as the
# kind of failures production creates that nobody writes on a
# whiteboard (unauthorized cancel, over-refund, cross-system
# mismatch). Setting `backtests=chronicle-demo` lands
# /dashboard/backtests directly on a completed Run that compares
# `billing-agent@1.0.0` against a candidate v1.1.0 fixing the three
# flagged failures. Set all five to `chronicle-demo` for the demo flow.
NEXT_PUBLIC_DATA_SEED_AGENTS=default
NEXT_PUBLIC_DATA_SEED_CONNECTIONS=default
NEXT_PUBLIC_DATA_SEED_DATASETS=default
NEXT_PUBLIC_DATA_SEED_TIMELINE=default
NEXT_PUBLIC_DATA_SEED_BACKTESTS=default
NEXT_PUBLIC_DATA_SEED_ENVIRONMENTS=default

# Optional latency jitter for mock mode (ms). 0 disables.
# NEXT_PUBLIC_DATA_MOCK_LATENCY_MS=120
