{
  "name": "chronicle-platform",
  "version": "0.1.0",
  "description": "Chronicle Labs Platform",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "turbo run dev",
    "dev:frontend": "turbo run dev --filter=frontend",
    "dev:env-manager": "turbo run dev --filter=env-manager",
    "dev:storybook": "turbo run storybook --filter=ui",
    "build:storybook": "turbo run build-storybook --filter=ui",
    "bones": "turbo run bones:build --filter=ui",
    "bones:watch": "turbo run bones:watch --filter=ui",
    "build": "turbo build",
    "build:frontend": "turbo build --filter=frontend",
    "build:env-manager": "turbo build --filter=env-manager",
    "db:push": "turbo run db:push",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:studio": "turbo run db:studio",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx}\" \"packages/**/*.{ts,tsx}\" \"nango-integrations/**/*.{ts,tsx}\"",
    "format:write": "prettier --write \"apps/**/*.{ts,tsx}\" \"packages/**/*.{ts,tsx}\" \"nango-integrations/**/*.{ts,tsx}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --cache --cache-location=node_modules/.cache/.eslintcache --fix",
    "lint:staged": "lint-staged --allow-empty",
    "test:rust": "cd backend && cargo test --workspace",
    "test:rust-full": "cd backend && cargo test --workspace --features postgres-tests",
    "test:contracts": "cd backend && cargo test --test contracts",
    "test:ai-sdk-capture": "yarn workspace @chroniclelabs/ai-sdk test",
    "test:ai-sdk-live-node": "yarn workspace @chroniclelabs/ai-sdk test:live-node",
    "test:e2e": "npx playwright test",
    "test:all": "yarn test:rust && yarn test:contracts && yarn test:e2e"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.14.0"
  },
  "packageManager": "yarn@4.6.0",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.8.0"
  }
}
