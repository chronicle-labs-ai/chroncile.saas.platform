# Chronicle Backend Configuration
# Copy this to .env and customize as needed

# Backend mode: "memory" (default) or "real"
# memory = in-memory backends (no external deps, fast)
# real = Kafka + Postgres (requires docker compose -f deploy/docker-compose.yml up -d)
BACKEND_MODE=memory

# Server configuration
API_HOST=127.0.0.1
API_PORT=3000

# Logging level
RUST_LOG=info,chronicle=debug,tower_http=debug

# Auth and service access
AUTH_SECRET=
SERVICE_SECRET=

# Sentry (optional)
SENTRY_DSN=https://962563178590206d935ae42ee0af131d@o4511003800109056.ingest.us.sentry.io/4511003805351936
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

# Public app URL used in backend-generated links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sandbox AI graph editing (optional)
# Powers the sandbox generative prompt through Anthropic's Messages API.
# SANDBOX_AI_API_KEY=
# SANDBOX_AI_API_URL=https://api.anthropic.com/v1/messages
# SANDBOX_AI_MODEL=claude-sonnet-4-6
# SANDBOX_AI_MAX_TOKENS=1024
# SANDBOX_AI_TEMPERATURE=0.0
# SANDBOX_AI_TIMEOUT_MS=30000

# Streaming configuration (memory mode)
STREAM_CHANNEL_CAPACITY=10000
STREAM_BUFFER_CAPACITY=100000

# Batching configuration (real mode)
BATCH_MAX_SIZE=1000
BATCH_MAX_WAIT_MS=50

# Real mode configuration (only needed with BACKEND_MODE=real)
# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=events.norm.v1
KAFKA_GROUP_ID=chronicle-backend

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/chronicle

# Email
# RESEND_API_KEY=
# RESEND_FROM_ADDRESS=Chronicle Labs <noreply@chronicle-labs.com>

# ===========================================
# Simulation Mode
# ===========================================
# Enable simulation mode to auto-generate events in a background task
# SIM_MODE=true

# Timing mode: "scenario" (realistic delays), "random" (fixed rate), "mixed" (both)
# SIM_TIMING=scenario

# Events per second (used in random and mixed modes)
# SIM_RATE=2.0

# Which scenarios to play: comma-separated ("refund", "escalation", "simple") or "all"
# SIM_SCENARIOS=all

# Which mock sources to include: comma-separated ("mock-connector", "mock-stripe")
# SIM_SOURCES=mock-connector

# Loop scenarios when exhausted (true/false)
# SIM_LOOP=true

# Tenant ID for simulated events
# SIM_TENANT=demo_tenant

# UI configuration
API_URL=http://127.0.0.1:3000

# ===========================================
# Integration Webhooks
# ===========================================
# Events from Intercom, Slack, Stripe, etc. are received via Pipedream
# in the chronicle-platform frontend and forwarded to this service via /api/ingest.
# Do not configure direct third-party webhook secrets here.
# STRIPE_WEBHOOK_SECRET=
